# Get a free key: https://www.themoviedb.org/settings/api
TMDB_API_KEY=

# Supabase (from project Settings → API)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Canonical HTTPS origin used for auth emails, payment redirects, and absolute links (no trailing slash)
# Local: http://127.0.0.1:3010
# Production (Vercel): https://glstv.site
NEXT_PUBLIC_SITE_URL=

# Vercel Cron authentication (random value, at least 16 characters)
CRON_SECRET=

# Optional: SA (or residential) HTTP proxy for geo streams like SABC 3
# Example: http://user:pass@za-proxy.example:8080
GLS_STREAM_PROXY=

# Server-only Supabase admin (NEVER NEXT_PUBLIC_*) — rotate if leaked in chat
SUPABASE_SERVICE_ROLE_KEY=

# Comma-separated emails allowed to use /eadmin stream seeding UI
# Owner admin t.cassim3@gmail.com is also built into the app (trial-exempt).
EADMIN_EMAILS=t.cassim3@gmail.com

# Launch billing — Yoco creates per-member payment links + QR codes.
# Keep server-only. EFT details are configured in Admin → Finance → Settings.
YOCO_SECRET_KEY=

# PayFast (SA card) — Individual/Sole Trader sandbox or live credentials.
# Sandbox: https://sandbox.payfast.co.za (Merchant ID / Key / Salt Passphrase under Settings)
# Live: https://www.payfast.co.za → Settings → Integration
# ITN notify URL (set in dashboard or per-transaction): https://YOUR_DOMAIN/api/payfast/itn
PAYFAST_MERCHANT_ID=
PAYFAST_MERCHANT_KEY=
PAYFAST_PASSPHRASE=
# true = sandbox.payfast.co.za · false = www.payfast.co.za
PAYFAST_SANDBOX=true

# Optional future Stripe recurring billing (dormant during manual/PayFast launch)
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_...
# STRIPE_SECRET_KEY=rk_... or sk_...
# STRIPE_WEBHOOK_SECRET=whsec_...
# STRIPE_PRICE_GLS_55=price_...
# STRIPE_PRICE_GLS_65=price_...
# STRIPE_PRICE_GLS_75=price_...
