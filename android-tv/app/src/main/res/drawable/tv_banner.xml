<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Android TV banner 320×180 -->
    <item>
        <shape android:shape="rectangle">
            <size
                android:width="320dp"
                android:height="180dp" />
            <solid android:color="@color/gls_black" />
        </shape>
    </item>
    <item
        android:bottom="0dp"
        android:left="0dp"
        android:right="0dp"
        android:top="0dp">
        <shape android:shape="rectangle">
            <gradient
                android:angle="135"
                android:endColor="#FF1A0508"
                android:startColor="#FFE50914"
                android:type="linear" />
        </shape>
    </item>
    <item
        android:bottom="48dp"
        android:left="28dp"
        android:right="28dp"
        android:top="48dp">
        <shape android:shape="rectangle">
            <solid android:color="#00000000" />
            <stroke
                android:width="2dp"
                android:color="@color/gls_white" />
        </shape>
    </item>
</layer-list>
